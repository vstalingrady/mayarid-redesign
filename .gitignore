# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local agent / browser tooling
.playwright-mcp/
mcps/
playwright-*.tgz

# mirrored upstream site (not shipped; ~90MB)
/reference/

# one-off QA screenshots dropped in repo root
/*.png

# temp scratch scripts
_dash.py
_dims.py
_measure-*.js
